<div class="min-h-screen bg-surface flex items-center justify-center p-8">
  <div class="card max-w-2xl w-full">
    <div class="card-body">
      <div class="text-center mb-8">
        <%= lucide_icon "folder-open", class: "w-16 h-16 text-primary mx-auto mb-4" %>
        <h1 class="text-3xl font-mono font-bold text-primary mb-2">Open Project</h1>
        <p class="text-secondary">Select an existing project or create a new one</p>
      </div>

      <!-- Recent Projects -->
      <% if @recent_projects.any? %>
        <div class="mb-8">
          <h2 class="text-lg font-mono font-semibold text-primary mb-4">Recent Projects</h2>
          <div class="space-y-2">
            <% @recent_projects.each do |project| %>
              <div class="card hover:shadow-lg transition-shadow cursor-pointer" onclick="this.querySelector('form').requestSubmit()">
                <div class="card-body">
                  <div class="flex items-start gap-3">
                    <%= lucide_icon "folder", class: "w-5 h-5 text-primary mt-0.5" %>
                    <div class="flex-1 min-w-0">
                      <h3 class="font-mono font-semibold text-primary"><%= project.name %></h3>
                      <p class="text-sm text-tertiary truncate"><%= project.absolute_path %></p>
                      <% if project.description.present? %>
                        <p class="text-sm text-secondary mt-1"><%= project.description %></p>
                      <% end %>
                    </div>
                    <span class="badge badge-secondary"><%= project.status %></span>
                  </div>
                  <%= button_to "Open", projects_path(coding_project: { name: project.name, absolute_path: project.absolute_path, description: project.description }), method: :post, class: "hidden" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Open New Project -->
      <div class="border-t border-border pt-8">
        <h2 class="text-lg font-mono font-semibold text-primary mb-4">Open New Project</h2>
        
        <%= form_with url: projects_path, method: :post, class: "space-y-4" do |f| %>
          <div>
            <%= f.label :name, "Project Name", class: "form-label" %>
            <%= f.text_field :name, class: "form-input", placeholder: "My Awesome Project", required: true %>
          </div>

          <div>
            <%= f.label :absolute_path, "Project Directory Path", class: "form-label" %>
            <%= f.text_field :absolute_path, class: "form-input font-mono", placeholder: "/home/user/projects/my-project", required: true %>
            <p class="text-sm text-tertiary mt-1">
              <%= lucide_icon "info", class: "w-3 h-3 inline-block" %>
              Absolute path to your project directory on the filesystem
            </p>
          </div>

          <div>
            <%= f.label :description, "Description (Optional)", class: "form-label" %>
            <%= f.text_area :description, rows: 3, class: "form-input", placeholder: "Brief description of your project" %>
          </div>

          <div class="flex gap-3">
            <%= f.submit "Open Project", class: "btn-primary flex-1" %>
          </div>
        <% end %>
      </div>

      <!-- Help Text -->
      <div class="mt-8 p-4 bg-surface-elevated rounded-lg border border-border">
        <div class="flex gap-3">
          <%= lucide_icon "lightbulb", class: "w-5 h-5 text-primary flex-shrink-0" %>
          <div class="text-sm text-secondary">
            <p class="font-semibold text-primary mb-1">Tips:</p>
            <ul class="list-disc list-inside space-y-1">
              <li>The directory must exist on your filesystem</li>
              <li>All files will be read/written directly to disk</li>
              <li>Only metadata is stored in the database</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
