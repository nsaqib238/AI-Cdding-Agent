<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-mono font-bold text-primary">AI Chat Conversations</h1>
    
    <button type="button" class="btn-primary">
      <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
      New Conversation
    </button>
  </div>

  <!-- New Conversation Modal (Simple inline for now) -->
  <div class="card mb-8">
    <div class="card-header">
      <h2 class="text-xl font-mono font-semibold text-primary">Start New Chat</h2>
    </div>
    <div class="card-body">
      <%= form_with model: Conversation.new, url: conversations_path, method: :post, class: "space-y-4" do |f| %>
        <div class="form-group">
          <%= f.label :title, "Conversation Title", class: "form-label" %>
          <%= f.text_field :title, class: "form-input", placeholder: "e.g., Build authentication system" %>
        </div>

        <div class="form-group">
          <%= f.label :project_id, "Project (Optional)", class: "form-label" %>
          <%= f.collection_select :project_id, CodingProject.all, :id, :name, 
              { prompt: "Select a project..." }, 
              { class: "form-select" } %>
        </div>

        <div class="flex justify-end">
          <%= f.submit "Start Conversation", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Conversations List -->
  <div class="grid gap-4">
    <% if @conversations.any? %>
      <% @conversations.each do |conversation| %>
        <%= link_to conversation_path(conversation), class: "card hover:border-primary transition-colors" do %>
          <div class="card-body">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <h3 class="text-lg font-mono font-semibold text-primary mb-2">
                  <%= conversation.title %>
                </h3>
                
                <% if conversation.project %>
                  <div class="flex items-center gap-2 text-sm text-secondary mb-2">
                    <%= lucide_icon "folder", class: "w-4 h-4" %>
                    <span><%= conversation.project.name %></span>
                  </div>
                <% end %>

                <div class="flex items-center gap-4 text-sm text-tertiary">
                  <div class="flex items-center gap-1">
                    <%= lucide_icon "message-circle", class: "w-4 h-4" %>
                    <span><%= conversation.messages.count %> messages</span>
                  </div>
                  <div class="flex items-center gap-1">
                    <%= lucide_icon "clock", class: "w-4 h-4" %>
                    <span><%= time_ago_in_words(conversation.updated_at) %> ago</span>
                  </div>
                </div>
              </div>

              <div class="flex-shrink-0">
                <%= lucide_icon "chevron-right", class: "w-5 h-5 text-tertiary" %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

      <!-- Pagination -->
      <div class="mt-6">
        <%= paginate @conversations %>
      </div>
    <% else %>
      <div class="card">
        <div class="card-body text-center py-12">
          <%= lucide_icon "message-circle", class: "w-16 h-16 text-tertiary mx-auto mb-4" %>
          <p class="text-secondary">No conversations yet. Start one above!</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
